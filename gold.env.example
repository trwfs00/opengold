# =============================================================================
#  gold.env  —  Gold Bot (XAUUSDM M1)
# =============================================================================

# -- MT5 credentials ----------------------------------------------------------
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=MetaQuotes-Demo

# -- Database -----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=opengold
DB_USER=opengold
DB_PASSWORD=opengold_local_pw

# -- AI / Claude models -------------------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_PRIMARY_MODEL=claude-haiku-4-5
CLAUDE_FALLBACK_MODEL=claude-sonnet-4-5

# -- Bot identity -------------------------------------------------------------
BOT_ID=gold
SYMBOL=XAUUSD
TIMEFRAME=M1
CONTRACT_SIZE=100          # oz per lot (XAUUSD standard)
API_PORT=8000

# -- Risk management ----------------------------------------------------------
RISK_PER_TRADE=0.002        # 0.2% of account equity per trade
MAX_CONCURRENT_TRADES=10
DAILY_DRAWDOWN_LIMIT=0.05   # 5% max daily loss before bot pauses
MIN_AI_CONFIDENCE=0.65      # minimum Claude confidence to open a trade
MAX_TRADES_PER_DAY=999      # effectively unlimited for gold

# Stop-loss range (USD)
MIN_SL_USD=5.00
MAX_SL_USD=20.00

# Take-profit constraints
MIN_TP_USD=5.00
MIN_RR_RATIO=1.8            # minimum reward:risk ratio required

# -- Strategy parameters ------------------------------------------------------
# ADX trend-following
ADX_TREND_THRESHOLD=25      # ADX > 25 = trending market

# ATR-based breakout
ATR_BREAKOUT_MULTIPLIER=1.5 # entry breakout threshold (× ATR)
ATR_LOOKBACK=14             # ATR period

# Bollinger Bands
BB_WIDTH_THRESHOLD=0.001    # min band width to trade (avoids flat markets)
BB_LOOKBACK=20              # BB period

# -- Trigger / signal scoring -------------------------------------------------
TRIGGER_MIN_SCORE=4.5       # min aggregate score to trigger AI evaluation
TRIGGER_MIN_SCORE_DIFF=2.0  # min gap between BUY and SELL scores

# -- Trailing stop + re-evaluation --------------------------------------------
# (defaults are used when these are not set; shown here for documentation)
# TRAIL_BE_RATIO=0.5         # move SL to BE when profit >= 50% of TP distance
# TRAIL_ATR_MULTIPLIER=1.5   # trail SL at 1.5× ATR behind price
# TRAIL_MIN_PROFIT_USD=200   # force BE if position touched +$200 profit
# REEVAL_MIN_COUNTER_SCORE=5.0
# REEVAL_INTERVAL_MINUTES=10
# PARTIAL_CLOSE_RATIO=0.5

# -- Timing -------------------------------------------------------------------
AI_INTERVAL_MINUTES=10      # how often Claude re-evaluates open positions
POLL_INTERVAL_SECONDS=5     # MT5 price poll frequency

# -- Journal ------------------------------------------------------------------
JOURNAL_TRADE_COUNT=10      # number of recent trades included in AI context

# -- DB write buffer (fault-tolerance) ----------------------------------------
DB_BUFFER_MAX_RECORDS=1000
DB_RETRY_INTERVAL_SECONDS=30
DB_MAX_RETRY_DURATION_SECONDS=3600
