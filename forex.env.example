# =============================================================================
#  forex.env  — Forex Bot (GBPUSD M5)
# =============================================================================

# -- MT5 credentials ----------------------------------------------------------
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=MetaQuotes-Demo

# -- Database ----------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openforex
DB_USER=opengold
DB_PASSWORD=opengold_local_pw

# -- AI ----------------------------------------------------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_PRIMARY_MODEL=claude-haiku-4-5
CLAUDE_FALLBACK_MODEL=claude-sonnet-4-5

# -- Multi-symbol identity ---------------------------------------------------------------------
BOT_ID=forex
SYMBOL=GBPUSD
TIMEFRAME=M5
CONTRACT_SIZE=100000
PIP_VALUE_PER_LOT=10
API_PORT=8001

# -- Risk --------------------------------------------------------------------------------------
RISK_PER_TRADE=0.01
MAX_CONCURRENT_TRADES=3
DAILY_DRAWDOWN_LIMIT=0.03
MIN_AI_CONFIDENCE=0.65
SL_PIPS_MIN=1
SL_PIPS_MAX=25
TP_PIPS_MIN=4
TP_PIPS_MAX=40
MIN_RR_RATIO=1.3
MAX_TRADES_PER_DAY=15

# -- Trigger -----------------------------------------------------------------------------------
TRIGGER_MIN_SCORE=4.0
TRIGGER_MIN_SCORE_DIFF=1.5
AI_INTERVAL_MINUTES=5

# -- Sessions (London + New York  07:00-20:59 UTC) ---------------------------------------------
TRADE_SESSIONS_UTC=7-21

# -- System ------------------------------------------------------------------------------------
DRY_RUN=false
POLL_INTERVAL_SECONDS=5
MT5_RECONNECT_RETRIES=3
MT5_RECONNECT_DELAY_BASE=2

# -- Trailing stop + re-evaluation (forex-tuned) -----------------------------------------------
# Move SL to breakeven when profit >= 30% of TP distance (earlier than gold default 50%)
TRAIL_BE_RATIO=0.3
# Trail SL at 1.2× ATR behind current price (tighter than gold default 1.5×)
TRAIL_ATR_MULTIPLIER=1.2
# Safety net: force breakeven even when no TP is set or TP is very far away
# 100 USD ensures any position that touched +$100 locks in breakeven
TRAIL_MIN_PROFIT_USD=100
# Re-evaluate every 5 min — counter-signal threshold lowered from 5.0 (gold) to 3.5 for forex
REEVAL_MIN_COUNTER_SCORE=3.5
REEVAL_INTERVAL_MINUTES=5
PARTIAL_CLOSE_RATIO=0.5
